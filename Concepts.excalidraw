      "isDeleted": false,
      "boundElements": [],
      "updated": 1772803525724,
      "link": null,
      "locked": false,
      "text": "Guards get used to other\nguard's patterns. If you\ninterrupt other guard's\npatterns you can walk where\nthey usually walk without\narousing suspicion, unless seen\nof course",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "4XZIiba0tdHOTHMHn_H6h",
      "originalText": "Guards get used to other guard's patterns. If you interrupt other guard's patterns you can walk where they usually walk without arousing suspicion, unless seen of course",
      "autoResize": true,
      "lineHeight": 1.25
    },
