      "versionNonce": 387617699,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772884467156,
      "link": null,
      "locked": false,
      "text": "Use an event bus for global\nevents, with subscribing\nindependent systems.\nIndividual entities do NOT\nsubscribe to it, rather high\nlevel systems do and pass\nmessages to the entities.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "NK_YgoIuZ8T28o-eVmy_M",
      "originalText": "Use an event bus for global events, with subscribing independent systems. Individual entities do NOT subscribe to it, rather high level systems do and pass messages to the entities.",
      "autoResize": true,
      "lineHeight": 1.25
    },
