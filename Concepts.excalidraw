      "boundElements": [],
      "updated": 1772825870484,
      "link": null,
      "locked": false,
      "text": "Emails should act as ways to\ninform the player of new\npenalties/challenges from raising\nsuspicion. e.g management saying\n\"report tailgaters\" or \"report all\nunauthorised access\" or \"more\nguards\".",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "dVPEXuHfB0_Ea9Ko9XA30",
      "originalText": "Emails should act as ways to inform the player of new penalties/challenges from raising suspicion. e.g management saying \"report tailgaters\" or \"report all unauthorised access\" or \"more guards\".",
      "autoResize": true,
      "lineHeight": 1.25
    },
