      "link": null,
      "locked": false,
      "text": "Tailgating through secure\ndoors should be very possible\nbut risky.\nPeople will report you at\nhigher suspicion levels (unless\nfriends) and be more\ncautious through doors. ",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "_1JDHCJgpvsygMHMScauO",
      "originalText": "Tailgating through secure doors should be very possible but risky.\nPeople will report you at higher suspicion levels (unless friends) and be more cautious through doors. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
