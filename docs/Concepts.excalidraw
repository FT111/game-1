      "updated": 1772544272403,
      "link": null,
      "locked": false,
      "text": "Roguelite.\nSuspicion meter increases if\ncaught in a day.\nDifferent penalties occur,\nlike desk checks (storage),\ncheck ins, or eventually\nbeing fired.\nBeing caught ends day.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "7EkSqF2mpA1FAh-ome61_",
      "originalText": "Roguelite.\nSuspicion meter increases if caught in a day.\nDifferent penalties occur, like desk checks (storage), check ins, or eventually being fired.\nBeing caught ends day.",
      "autoResize": true,
      "lineHeight": 1.25
    },
