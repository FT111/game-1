    {
      "id": "5U0GK6uaMSEdzwrycSOwN",
      "type": "text",
      "x": 1669.7656610250376,
      "y": -68.66032191646141,
      "width": 237.03977966308594,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
