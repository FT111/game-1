    {
      "id": "4fAdJd0yCi8L6uZ9TK98Z",
      "type": "text",
      "x": 1845.4650030147607,
      "y": 1029.7390834837133,
      "width": 257.64776611328125,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
