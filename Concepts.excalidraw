      "versionNonce": 1892850419,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1772825878050,
      "link": null,
      "locked": false,
      "text": "Cauld also, as a late-stage\nfeature, allow for emailing\ncontacts found around the map\nfor stuff like requesting\nmaintanance to an area (leaves a\ndoor open) or reporting false\nintruders/security issues\n(reroutes guards to area but\nincreases suspicion).",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "j4SpSM2vcM2La4DnUFyrb",
      "originalText": "Cauld also, as a late-stage feature, allow for emailing contacts found around the map for stuff like requesting maintanance to an area (leaves a door open) or reporting false intruders/security issues (reroutes guards to area but increases suspicion).",
      "autoResize": true,
      "lineHeight": 1.25
    },
