    {
      "id": "VdE8HsQGbdUmjCyrHhTau",
      "type": "text",
      "x": 1660.2216332615367,
      "y": 120.12257282038124,
      "width": 252.39976501464844,
      "height": 140,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
